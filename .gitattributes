# Bei Merge-Konflikten von composer.lock die eigene Version behalten.
# Hinweis: Git speichert die Implementierung des merge=ours-Treibers nicht in .gitattributes,
# sondern benötigt zusätzlich einmalig: git config merge.ours.driver true
composer.lock merge=ours

